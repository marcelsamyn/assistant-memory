{
  "private": false,
  "name": "@marcelsamyn/memory",
  "version": "1.4.0",
  "type": "module",
  "main": "dist/server/index.mjs",
  "types": "dist/server/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server/index.mjs",
      "types": "./dist/server/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./sdk/*": {
      "import": "./dist/sdk/*.js",
      "types": "./dist/sdk/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nitro build",
    "build-sdk": "tsc --project tsconfig.sdk.json && tsc-alias --project tsconfig.sdk.json --resolve-full-paths --resolve-full-extension .js && node scripts/verify-sdk-build.mjs",
    "verify-sdk": "node scripts/verify-sdk-build.mjs",
    "dev": "nitro dev",
    "prepare": "nitro prepare",
    "preview": "node .output/server/index.mjs",
    "tsx": "tsx",
    "test": "vitest",
    "check:structured-outputs": "tsx scripts/check-structured-output-schemas.ts",
    "build:check": "tsc --noEmit && pnpm run check:structured-outputs",
    "lint": "eslint src --ext .js,.mjs,.cjs,.ts",
    "lint:fix": "eslint src --ext .js,.mjs,.cjs,.ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "drizzle:push": "drizzle-kit push",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio",
    "eval:memory": "tsx src/evals/memory/run-all.ts",
    "eval:identity-thresholds": "tsx src/evals/memory/threshold-calibration.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/content-type": "^1.1.8",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "ajv": "^8.20.0",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.24.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "globals": "^16.0.0",
    "nitro-test-utils": "^0.9.2",
    "nitropack": "latest",
    "prettier": "^3.5.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.3"
  },
  "packageManager": "pnpm@10.7.1+sha512.2d92c86b7928dc8284f53494fb4201f983da65f0fb4f0d40baafa5cf628fa31dae3e5968f12466f17df7e97310e30f343a648baea1b9b350685dafafffdf5808",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "bullmq": "^5.50.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0",
    "h3-nightly": "1.15.1-20250222-111608-d1c00fc",
    "ioredis": "^5.6.1",
    "minio-js": "^1.0.7",
    "openai": "^4.91.1",
    "pg": "^8.14.1",
    "typeid-js": "^1.2.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
